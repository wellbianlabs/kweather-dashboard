# 이 파일을 .env 로 복사해 값을 조정하세요. (없어도 기본값으로 동작)

# --- 데이터베이스 ---
# 기본: 설정 불필요한 SQLite. PostgreSQL 전환 시 아래 한 줄만 교체하고
# requirements.txt 의 psycopg2-binary 주석을 해제 후 재설치하세요.
# DATABASE_URL=postgresql+psycopg2://postgres:kweather2026@localhost:5432/kweather
# DATABASE_URL=sqlite:///./kweather.db

# --- 외부 날씨(기상청) ---
WEATHER_PROVIDER=mock           # mock | kma
# KMA_API_KEY=공공데이터포털_서비스키

# --- 폭염 위험 임계값 (체감온도 ℃) ---
# HEAT_ATTENTION=31
# HEAT_CAUTION=33
# HEAT_WARNING=35
# HEAT_DANGER=38

# 외부 대비 내부 체감온도 격차 경고 임계(℃)
# ENCLOSED_DELTA_ALERT=5
